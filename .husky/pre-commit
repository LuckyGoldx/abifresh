#!/bin/sh
# Pre-commit hook to detect and prevent accidental credential commits
# This hook checks for common secret patterns before allowing commits

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Exit code
EXIT_CODE=0

# Patterns to detect (avoid overly strict patterns that trigger false positives)
# Check for actual JWT tokens, API keys, and other secrets

# Function to check for secret patterns in a file
check_file_for_secrets() {
    local file=$1
    local found_secret=0
    
    # Check for JWT tokens (starts with eyJ, common JWT prefix)
    if grep -q "eyJ[A-Za-z0-9_-]*\." "$file" 2>/dev/null; then
        # But allow it in package-lock.json and similar (false positives)
        if ! [[ "$file" =~ (package-lock|yarn.lock|node_modules) ]]; then
            echo -e "${RED}⚠️  Potential JWT token found in: $file${NC}"
            found_secret=1
        fi
    fi
    
    # Check for Vercel OIDC tokens (bearToken, oidc patterns)
    if grep -qi "vercel.*token\|oidc.*token" "$file" 2>/dev/null; then
        if grep -E "eyJ[A-Za-z0-9_-]*\.[A-Za-z0-9_-]*\.[A-Za-z0-9_-]*" "$file" > /dev/null 2>&1; then
            echo -e "${RED}⚠️  Potential Vercel OIDC token found in: $file${NC}"
            found_secret=1
        fi
    fi
    
    # Check for AWS/GCP credentials patterns (AKIA, GOOG, etc.)
    if grep -qE "AKIA[0-9A-Z]{16}|GOOG[A-Za-z0-9_]+" "$file" 2>/dev/null; then
        echo -e "${RED}⚠️  Potential AWS/GCP credential found in: $file${NC}"
        found_secret=1
    fi
    
    # Check for obviously exposed secrets in variable assignments
    if grep -qE "SECRET|PASSWORD|KEY|TOKEN" "$file" 2>/dev/null; then
        # Check if it looks like a real secret (not just placeholder)
        if grep -E "(SECRET|PASSWORD|KEY|TOKEN)\s*=\s*['\"]?[^'\"\n\s]{20,}['\"]?" "$file" | grep -vqE "(your-|placeholder|example|TODO|ROTATE)" 2>/dev/null; then
            # More detailed check - look for actual token/key patterns
            if grep -E "(SECRET|PASSWORD|KEY|TOKEN)\s*=\s*eyJ|ey[A-Za-z0-9]" "$file" > /dev/null 2>&1; then
                echo -e "${RED}⚠️  Potential exposed credential in: $file${NC}"
                found_secret=1
            fi
        fi
    fi
    
    return $found_secret
}

# Get the list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Check each staged file
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip certain files that are known to have false positives
        if [[ "$file" =~ \.(lock|md|json)$ ]] && [[ ! "$file" =~ \.env ]]; then
            continue
        fi
        
        # Always check .env, .env.local and similar files strictly
        if [[ "$file" =~ \.env ]]; then
            # For .env files, check for any non-placeholder values
            if grep -E "^[A-Z_]+\s*=\s*[^']" "$file" | grep -vqE "=\s*(http://|https://|your-|placeholder|example|TODO)" 2>/dev/null; then
                if grep -E "^(JWT_SECRET|SUPABASE_.*KEY|VERCEL_OIDC|API_KEY|PASSWORD|TOKEN)\s*=\s*[^'\"]" "$file" | grep -vqE "placeholder|example|your-|TODO" 2>/dev/null; then
                    echo -e "${RED}❌ COMMIT BLOCKED: Real credentials detected in $file${NC}"
                    echo -e "${YELLOW}   ℹ️  Use placeholder values: 'your-secret-here' or 'placeholder-value'${NC}"
                    EXIT_CODE=1
                fi
            fi
        else
            check_file_for_secrets "$file"
            if [ $? -eq 1 ]; then
                EXIT_CODE=1
            fi
        fi
    fi
done

# Final message
if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✅ Secret check passed${NC}"
else
    echo -e "${RED}❌ Pre-commit check FAILED${NC}"
    echo -e "${YELLOW}Commit blocked to prevent credential exposure. Review secrets and try again.${NC}"
fi

exit $EXIT_CODE
